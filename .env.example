# =============================================================================
# Environment variable template — copy to .env and fill in real values.
# Never commit .env to version control.
# =============================================================================

# App environment: "development" | "production"
# Controls database connection method (proxy vs. Cloud SQL Connector)
ENVIRONMENT=development

# GCP project configuration
GCP_PROJECT_ID=your-project-id
GCP_REGION=your-region

# Cloud SQL database credentials
DB_NAME=your-database-name
DB_USER=your-database-user
DB_PASSWORD=your-database-password

# Development: used when ENVIRONMENT=development (connect via Cloud SQL Auth Proxy)
DB_HOST=localhost
DB_PORT=5432

# Production: used when ENVIRONMENT=production (Cloud SQL Python Connector)
INSTANCE_CONNECTION_NAME=your-project:your-region:your-instance

# Reducto API key (https://reducto.ai)
REDUCTO_API_KEY=your-reducto-api-key

# Frontend API base URL (used during local development by the React dev server)
VITE_API_URL=http://localhost:8080
